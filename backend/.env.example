# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/sai_iti_fee_db"

# ─── JWT Auth ──────────────────────────────────────────────
JWT_SECRET="your_super_secret_jwt_key_change_in_production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="your_refresh_token_secret_change_in_production"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Razorpay ─────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
STRIPE_PUBLISHABLE_KEY="pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
STRIPE_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXXXXXXXXXX"

# ─── Twilio (SMS + WhatsApp) ──────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ─── Email (SMTP via Nodemailer) ──────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your_school_email@gmail.com"
SMTP_PASS="your_app_password"
EMAIL_FROM="Sai ITI <your_school_email@gmail.com>"

# ─── Frontend URL (for CORS) ──────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── School Defaults ──────────────────────────────────────
SCHOOL_NAME="Sai ITI"
SCHOOL_ADDRESS="Your School Address, City, State - PIN"
SCHOOL_PHONE="+91XXXXXXXXXX"
SCHOOL_EMAIL="principal@saiiti.edu.in"
